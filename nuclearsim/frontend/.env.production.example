# Copy to .env.production and fill in the public URL of your tunneled
# local backend before running `npm run build`.
#
#   cp .env.production.example .env.production
#   cloudflared tunnel --url http://localhost:8000
#   # grab the https://*.trycloudflare.com URL it prints
#   # paste it below, then `npm run build`
VITE_API_BASE=https://pure-aruba-strategies-saturday.trycloudflare.com 
